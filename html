<script>
(function(){
  /* cursor */
  var c=document.getElementById('cur');
  if(c&&window.matchMedia('(pointer:fine)').matches){
    var x=-300,y=-300;
    document.addEventListener('mousemove',function(e){x=e.clientX;y=e.clientY;},{passive:true});
    (function t(){c.style.left=x+'px';c.style.top=y+'px';requestAnimationFrame(t);})();
    document.querySelectorAll('a,button').forEach(function(el){
      el.addEventListener('mouseenter',function(){c.classList.add('big');});
      el.addEventListener('mouseleave',function(){c.classList.remove('big');});
    });
  }

  /* nav */
  var nav=document.getElementById('nav');
  window.addEventListener('scroll',function(){nav.classList.toggle('stuck',window.scrollY>50);},{passive:true});

  /* mobile menu */
  var h=document.getElementById('ham'),m=document.getElementById('mob');
  if(h&&m){
    h.addEventListener('click',function(){
      var o=!m.classList.contains('open');
      m.classList.toggle('open',o);
      h.classList.toggle('open',o);
      document.body.style.overflow=o?'hidden':'';
    });
  }
  window.cM=function(){
    if(m)m.classList.remove('open');
    if(h)h.classList.remove('open');
    document.body.style.overflow='';
  };

  /* CTA lines */
  var vl=document.getElementById('vlines');
  if(vl){
    var n=window.innerWidth<600?4:8;
    for(var i=0;i<n;i++){var l=document.createElement('div');l.className='vl';l.style.left=((i+1)/(n+1)*100)+'%';vl.appendChild(l);}
  }

  /* scroll reveal */
  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('on');io.unobserve(e.target);}});},{threshold:0.07});
  document.querySelectorAll('.r,.rr').forEach(function(el){io.observe(el);});

  /* stagger */
  ['.plst','.sgrid','.sg','.pg2','.wrws','.band-in'].forEach(function(s){
    var g=document.querySelector(s);
    if(g)g.querySelectorAll('.r,.rr').forEach(function(el,i){el.style.transitionDelay=(i*0.065)+'s';});
  });

  /* CTA animate on scroll */
  var ct=document.querySelector('.cta');
  if(ct){
    var co=new IntersectionObserver(function(es){if(es[0].isIntersecting){ct.classList.add('live');co.disconnect();}},{threshold:0.15});
    co.observe(ct);
  }

  /* parallax ghost */
  var hg=document.querySelector('.hg');
  if(hg){
    window.addEventListener('scroll',function(){hg.style.transform='translateY(calc(-50% + '+window.scrollY*.12+'px))';},{passive:true});
  }
})();
</script>
